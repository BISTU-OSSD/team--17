# DevSkillMapper - 环境变量配置
# 复制此文件为 .env 并填入实际值

# LLM 服务器配置
# LLAMA_SERVER=D:\path\to\llama-cpp\llama-server.exe
# MODEL_PATH=D:\path\to\Qwen3.5-9B-Q4_K_M.gguf
HOST=127.0.0.1
PORT=8080

# GitHub Personal Access Token（可选，有 Token 可获 5000 req/h，无则 60 req/h）
# 获取地址：https://github.com/settings/tokens
GITHUB_TOKEN=

# SSL 证书验证（生产环境建议 true；部分 Windows 开发环境可能需设为 false）
VERIFY_SSL=true

# 缓存配置
CACHE_TTL_SECONDS=600        # 缓存有效期（秒），默认 10 分钟
CACHE_MAX_ENTRIES=200        # 内存最大缓存条目
USE_SQLITE_CACHE=false       # 是否启用 SQLite 持久缓存
SQLITE_CACHE_PATH=cache.db   # SQLite 缓存文件路径

# 请求配置
REQUEST_TIMEOUT=15           # HTTP 请求超时（秒）
MAX_RETRIES=3               # 最大重试次数
RETRY_BACKOFF=1.5           # 重试退避因子
